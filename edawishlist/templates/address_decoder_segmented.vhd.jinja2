{%- if segment_size is defined %}
-- Automatically generated by WhishList - https://github.com/mvsoliveira/wishlist
-- File name: {{ name.lower() }}_address_decoder_segmented
-- Description : {{ description }}
--
-- Segmented pipelined address decoder — 2-stage pipeline:
--   Stage 1: decodes region index from address, fans out address/data/enables
--            to N independent region slices (reduces fanout on long nets)
--   Stage 2: each region decodes only its local offset bits in parallel
--   Stage 3: OR-merges all region read-data outputs (same cycle as Stage 2)
--
-- Latency: 2 clock cycles (vs 1 for the flat decoder)

{# ===== REGION_SIZE comes from segment_size in the YAML ===== #}
{%- set REGION_SIZE = segment_size %}

{# ===== DERIVED CONSTANTS — computed from REGION_SIZE and address_size ===== #}
{%- set NUM_REGIONS = (address_size / REGION_SIZE) | int %}

{# ===== ACTIVE REGION RANGE — only regions that contain at least one register ===== #}
{%- set min_addr = address_decoder['address'].min() %}
{%- set max_addr = address_decoder['address'].max() %}
{%- set FIRST_REGION = ((min_addr - address) // REGION_SIZE) | int %}
{%- set LAST_REGION  = ((max_addr - address) // REGION_SIZE) | int %}
{%- set ACTIVE_REGIONS = LAST_REGION - FIRST_REGION + 1 %}

{# log2(REGION_SIZE) → number of offset bits #}
{%- set _ns = namespace(bits=0, tmp=REGION_SIZE) %}
{%- for _ in range(32) %}
  {%- if _ns.tmp > 1 %}
    {%- set _ns.tmp  = _ns.tmp // 2 %}
    {%- set _ns.bits = _ns.bits + 1 %}
  {%- endif %}
{%- endfor %}
{%- set OFFSET_BITS = _ns.bits %}

{# log2(NUM_REGIONS) → number of region-select bits #}
{%- set _ns2 = namespace(bits=0, tmp=NUM_REGIONS) %}
{%- for _ in range(32) %}
  {%- if _ns2.tmp > 1 %}
    {%- set _ns2.tmp  = _ns2.tmp // 2 %}
    {%- set _ns2.bits = _ns2.bits + 1 %}
  {%- endif %}
{%- endfor %}
{%- set REGION_BITS = _ns2.bits %}

{# Address slice: bits[OFFSET_BITS + REGION_BITS - 1 : OFFSET_BITS] select the region  #}
{# Address slice: bits[OFFSET_BITS - 1 : 0]                          select word within region #}
{%- set SLICE_REG_HIGH = OFFSET_BITS + REGION_BITS - 1 %}
{%- set SLICE_REG_LOW  = OFFSET_BITS %}
{%- set SLICE_OFF_HIGH = OFFSET_BITS - 1 %}
{%- set SLICE_OFF_LOW  = 0 %}

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
library work;
use work.{{ name.lower() }}_pkg.all;

entity {{ name.lower() }}_address_decoder is
port(
    clk_i       : in  std_logic;
    read_i      : in  std_logic;
    write_i     : in  std_logic;
    address_i   : in  std_logic_vector({{ address_width - 1 }} downto 0);
    data_i      : in  std_logic_vector(31 downto 0);
    data_o      : out std_logic_vector(31 downto 0);
    write_ack_o : out std_logic;
    read_ack_o  : out std_logic;
    error_o     : out std_logic;
    {{ name.lower() }}_status_i  : in  {{ name.lower() }}_status_record_type;
    {{ name.lower() }}_control_o : out {{ name.lower() }}_control_record_type
);
end entity {{ name.lower() }}_address_decoder;

architecture rtl of {{ name.lower() }}_address_decoder is

    signal int_{{ name.lower() }}_control : {{ name.lower() }}_control_record_type;
    signal int_{{ name.lower() }}_status  : {{ name.lower() }}_status_record_type;
    signal write_ack_int : std_logic;
    signal read_ack_int  : std_logic;
    signal error_int     : std_logic;

    -- {{ NUM_REGIONS }} total regions x {{ segment_size }} bytes (segment_size); {{ ACTIVE_REGIONS }} active (regions {{ FIRST_REGION }}–{{ LAST_REGION }})
    -- Region select : address_i[{{ SLICE_REG_HIGH }}:{{ SLICE_REG_LOW }}]
    -- Offset within : address_i[{{ SLICE_OFF_HIGH }}:{{ SLICE_OFF_LOW }}]
    type t_slv32_array is array ({{ FIRST_REGION }} to {{ LAST_REGION }}) of std_logic_vector(31 downto 0);

    signal pipe_addr         : t_slv32_array;   -- address replicated per region
    signal pipe_data         : t_slv32_array;   -- write data replicated per region
    signal pipe_we           : std_logic_vector({{ FIRST_REGION }} to {{ LAST_REGION }});
    signal pipe_re           : std_logic_vector({{ FIRST_REGION }} to {{ LAST_REGION }});
    signal read_data_regions : t_slv32_array;   -- per-region read data (OR-merged in Stage 3)

    attribute syn_preserve : boolean;
    attribute syn_preserve of pipe_addr         : signal is true;
    attribute syn_preserve of pipe_data         : signal is true;
    attribute syn_preserve of pipe_we           : signal is true;
    attribute syn_preserve of pipe_re           : signal is true;
    attribute syn_preserve of read_data_regions : signal is true;

    attribute maxfan : integer;
    attribute maxfan of pipe_addr : signal is 200;

begin

    {{ name.lower() }}_control_o <= int_{{ name.lower() }}_control;
    int_{{ name.lower() }}_status <= {{ name.lower() }}_status_i;

    -- =========================================================================
    -- STAGE 1: Fan-out pipeline
    -- Replicates address + data to every region slice; asserts pipe_we/pipe_re
    -- only for the selected region. syn_preserve keeps the registers separate.
    -- =========================================================================
    pipeline_p : process(clk_i) is
    begin
        if rising_edge(clk_i) then
            pipe_we <= (others => '0');
            pipe_re <= (others => '0');
            for i in {{ FIRST_REGION }} to {{ LAST_REGION }} loop
                pipe_addr(i) <= address_i;
                pipe_data(i) <= data_i;
            end loop;
            if write_i = '1' then
                pipe_we(to_integer(unsigned(address_i({{ SLICE_REG_HIGH }} downto {{ SLICE_REG_LOW }})))) <= '1';
            end if;
            if read_i = '1' then
                pipe_re(to_integer(unsigned(address_i({{ SLICE_REG_HIGH }} downto {{ SLICE_REG_LOW }})))) <= '1';
            end if;
        end if;
    end process pipeline_p;

    -- =========================================================================
    -- STAGE 2: Local decode per region
    -- Each active region decodes only offset bits [{{ SLICE_OFF_HIGH }}:{{ SLICE_OFF_LOW }}].
    -- STAGE 3: OR-merge of all region read-data outputs into data_o.
    -- =========================================================================
    address_decoder_p : process(clk_i) is
        variable v_read_data : std_logic_vector(31 downto 0);
    begin
        if rising_edge(clk_i) then
            write_ack_int     <= '0';
            read_ack_int      <= '0';
            error_int         <= '0';
            read_data_regions <= (others => (others => '0'));

{%- for region_idx in range(FIRST_REGION, LAST_REGION + 1) %}
{%- set region_start_abs = address + region_idx * REGION_SIZE %}
{%- set region_end_abs   = address + (region_idx + 1) * REGION_SIZE %}
{%- set region_df = address_decoder[address_decoder.address >= region_start_abs] %}
{%- set region_df = region_df[region_df.address < region_end_abs] %}
{%- if not region_df.empty %}
            -- -----------------------------------------------------------------
            -- REGION {{ region_idx }}: 0x{{ '%08X' % region_start_abs }} – 0x{{ '%08X' % (region_end_abs - 1) }}
            -- -----------------------------------------------------------------
{%- set write_df = region_df[region_df.permission == 'rw'] %}
{%- if not write_df.empty %}
            if pipe_we({{ region_idx }}) = '1' then
                write_ack_int <= '1';
                case pipe_addr({{ region_idx }})({{ SLICE_OFF_HIGH }} downto {{ SLICE_OFF_LOW }}) is
{%- for addr in write_df['address'].unique() %}
{%- set group = write_df[write_df.address == addr] %}
                    when "{{ ('{:0' ~ OFFSET_BITS ~ 'b}').format(addr - region_start_abs) }}" => -- 0x{{ '%08X' % addr }}
{%- for _, row in group.iterrows() %}
{%- set addr_bits = row['address_bits_lists'] %}
{%- set reg_bits  = row['register_bits_lists'] %}
{%- set signal    = 'int_' + row['vhdl_member_name'] %}
{%- set is_vec    = row['node_width'] > 1 %}
{%- if addr_bits | length == 1 %}
{%- if is_vec %}
                        {{ signal }}({{ reg_bits[0] }}) <= pipe_data({{ region_idx }})({{ addr_bits[0] }});
{%- else %}
                        {{ signal }} <= pipe_data({{ region_idx }})({{ addr_bits[0] }});
{%- endif %}
{%- else %}
{%- if is_vec %}
                        {{ signal }}({{ reg_bits[0] }} downto {{ reg_bits[-1] }}) <= pipe_data({{ region_idx }})({{ addr_bits[0] }} downto {{ addr_bits[-1] }});
{%- else %}
                        {{ signal }} <= pipe_data({{ region_idx }})({{ addr_bits[0] }} downto {{ addr_bits[-1] }});
{%- endif %}
{%- endif %}
{%- endfor %}
{%- endfor %}
                    when others => null;
                end case;
            end if;
{%- endif %}
{%- set read_df = region_df[region_df.permission.str.contains('r')] %}
{%- if not read_df.empty %}
            if pipe_re({{ region_idx }}) = '1' then
                read_ack_int <= '1';
                case pipe_addr({{ region_idx }})({{ SLICE_OFF_HIGH }} downto {{ SLICE_OFF_LOW }}) is
{%- for addr in read_df['address'].unique() %}
{%- set group = read_df[read_df.address == addr] %}
                    when "{{ ('{:0' ~ OFFSET_BITS ~ 'b}').format(addr - region_start_abs) }}" => -- 0x{{ '%08X' % addr }}
{%- for _, row in group.iterrows() %}
{%- set addr_bits = row['address_bits_lists'] %}
{%- set reg_bits  = row['register_bits_lists'] %}
{%- set signal    = 'int_' + row['vhdl_member_name'] %}
{%- set is_vec    = row['node_width'] > 1 %}
{%- if addr_bits | length == 1 %}
{%- if is_vec %}
                        read_data_regions({{ region_idx }})({{ addr_bits[0] }}) <= {{ signal }}({{ reg_bits[0] }});
{%- else %}
                        read_data_regions({{ region_idx }})({{ addr_bits[0] }}) <= {{ signal }};
{%- endif %}
{%- else %}
{%- if is_vec %}
                        read_data_regions({{ region_idx }})({{ addr_bits[0] }} downto {{ addr_bits[-1] }}) <= {{ signal }}({{ reg_bits[0] }} downto {{ reg_bits[-1] }});
{%- else %}
                        read_data_regions({{ region_idx }})({{ addr_bits[0] }} downto {{ addr_bits[-1] }}) <= {{ signal }};
{%- endif %}
{%- endif %}
{%- endfor %}
{%- endfor %}
                    when others => null;
                end case;
            end if;
{%- endif %}
{%- endif %}
{%- endfor %}

            -- Stage 3: OR-merge read data — only the active region drives non-zero bits
            v_read_data := (others => '0');
            for i in {{ FIRST_REGION }} to {{ LAST_REGION }} loop
                v_read_data := v_read_data or read_data_regions(i);
            end loop;
            data_o      <= v_read_data;
            write_ack_o <= write_ack_int;
            read_ack_o  <= read_ack_int;
            error_o     <= error_int;

        end if;
    end process address_decoder_p;

end architecture rtl;
{%- endif %}
